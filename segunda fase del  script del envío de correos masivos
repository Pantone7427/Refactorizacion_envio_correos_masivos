function confirmarEnvioMasivo() {
  const ui = SpreadsheetApp.getUi();
  const respuesta = ui.alert(
    'Envío masivo de correos',
    '¿Confirmas el envío?\n\n' +
    '• Solo se procesarán los NIT sin estado "ENVIADO"\n' +
    '• Se adjuntarán todos los soportes por inmueble\n' +
    '• Se actualizarán las columnas de control',
    ui.ButtonSet.YES_NO
  );

  if (respuesta !== ui.Button.YES) {
    ui.alert('Cancelado', 'No se envió ningún correo.', ui.ButtonSet.OK);
    return;
  }

  ui.alert('Procesando...', 'El envío ha comenzado. Esto puede tardar unos minutos.', ui.ButtonSet.OK);
  enviarCorreosMasivos();
  ui.alert('Proceso completado', 'Revisa la columna "Estado" para ver los resultados.', ui.ButtonSet.OK);
}

function confirmarReset() {
  const ui = SpreadsheetApp.getUi();
  const respuesta = ui.alert(
    'Restablecer estados',
    'Advertencia: esto borrará todos los estados de envío.\n\n¿Deseas continuar?',
    ui.ButtonSet.YES_NO
  );

  if (respuesta === ui.Button.YES) {
    restablecerEstados();
    ui.alert('Completado', 'Los estados han sido restablecidos.', ui.ButtonSet.OK);
  }
}


// ============================================================
//  RESTABLECER ESTADOS
// ============================================================

function restablecerEstados() {
  const hoja       = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(NOMBRE_HOJA);
  const encabezados = hoja.getRange(1, 1, 1, hoja.getLastColumn()).getValues()[0];
  const ultimaFila  = hoja.getLastRow();

  const cols = ["Estado", "Fecha Envío", "Hora Envío"].map(n => encabezados.indexOf(n) + 1);
  cols.filter(c => c > 0).forEach(c => {
    hoja.getRange(2, c, ultimaFila - 1, 1).clearContent();
  });

  Logger.log("Estados restablecidos correctamente.");
}


// ============================================================
//  RESUMEN DE ENVÍOS
// ============================================================

function mostrarResumenEnvios() {
  const hoja       = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(NOMBRE_HOJA);
  const datos      = hoja.getDataRange().getDisplayValues();
  const colEstado  = datos[0].indexOf("Estado");

  if (colEstado === -1) {
    SpreadsheetApp.getUi().alert('Aviso', 'Aún no se ha ejecutado ningún envío.', SpreadsheetApp.getUi().ButtonSet.OK);
    return;
  }

  // Tomar solo el primer estado encontrado por NIT
  const nitVistos = {};
  for (let i = 1; i < datos.length; i++) {
    const nit    = datos[i][COL_NIT].trim();
    const estado = datos[i][colEstado];
    if (!nitVistos[nit]) nitVistos[nit] = estado;
  }

  const conteo = { enviados: 0, sinEmail: 0, sinArchivo: 0, errores: 0, pendientes: 0 };
  for (const estado of Object.values(nitVistos)) {
    if (estado === "ENVIADO")         conteo.enviados++;
    else if (estado === "SIN EMAIL")  conteo.sinEmail++;
    else if (estado === "SIN ARCHIVO") conteo.sinArchivo++;
    else if (estado.startsWith("ERROR")) conteo.errores++;
    else                              conteo.pendientes++;
  }

  const total   = Object.keys(nitVistos).length;
  const mensaje =
    `RESUMEN DE ENVÍOS\n\n` +
    `Total de administraciones: ${total}\n\n` +
    `Enviados:    ${conteo.enviados}\n` +
    `Pendientes:  ${conteo.pendientes}\n` +
    `Sin email:   ${conteo.sinEmail}\n` +
    `Sin archivo: ${conteo.sinArchivo}\n` +
    `Errores:     ${conteo.errores}`;

  SpreadsheetApp.getUi().alert('Resumen de envíos', mensaje, SpreadsheetApp.getUi().ButtonSet.OK);
}


// ============================================================
//  FUNCIÓN PRINCIPAL DE ENVÍO
// ============================================================

function enviarCorreosMasivos() {
  const ss   = SpreadsheetApp.getActiveSpreadsheet();
  const hoja = ss.getSheetByName(NOMBRE_HOJA);
  const datos = hoja.getDataRange().getDisplayValues();
  const encabezados = datos[0];

  // Obtener (o crear) columnas de control
  const colEstado = obtenerOCrearColumna(hoja, encabezados, "Estado");
  const colFecha  = obtenerOCrearColumna(hoja, encabezados, "Fecha Envío");
  const colHora   = obtenerOCrearColumna(hoja, encabezados, "Hora Envío");

  const mapaArchivos = cargarArchivosDesideDrive();
  const nitAgrupado  = agruparFilasPorNit(datos);

  let stats = { enviados: 0, omitidos: 0, errores: 0 };

  for (const nit in nitAgrupado) {
    const admin = nitAgrupado[nit];

    // Si ya fue enviado en una ejecución anterior, lo saltamos
    const estadoActual = hoja.getRange(admin.filas[0].filaExcel, colEstado).getDisplayValue();
    if (estadoActual === "ENVIADO") {
      Logger.log(`Omitiendo ${admin.nombreAdmin} — ya fue enviado.`);
      stats.omitidos++;
      continue;
    }

    if (!admin.email) {
      Logger.log(`Sin email: ${admin.nombreAdmin}`);
      registrarEstado(hoja, admin.filas, colEstado, colFecha, colHora, "SIN EMAIL");
      stats.errores++;
      continue;
    }

    const { adjuntos, faltantes } = resolverAdjuntos(admin.filas, mapaArchivos);

    if (faltantes.length > 0) {
      Logger.log(`Faltan ${faltantes.length} archivo(s) para ${admin.nombreAdmin} — correo no enviado.`);
      registrarEstado(hoja, admin.filas, colEstado, colFecha, colHora, "SIN ARCHIVO");
      stats.errores++;
      continue;
    }

    try {
      enviarCorreo(admin, adjuntos);
      registrarEstado(hoja, admin.filas, colEstado, colFecha, colHora, "ENVIADO");
      SpreadsheetApp.flush();
      Logger.log(`Enviado a ${admin.nombreAdmin} (${admin.email}) — ${adjuntos.length} adjunto(s).`);
      stats.enviados++;
    } catch (err) {
      Logger.log(`Error al enviar a ${admin.nombreAdmin}: ${err.message}`);
      registrarEstado(hoja, admin.filas, colEstado, colFecha, colHora, "ERROR: " + err.message);
      SpreadsheetApp.flush();
      stats.errores++;
    }

    Utilities.sleep(1000);
  }

  Logger.log(`--- Proceso completado: ${stats.enviados} enviados, ${stats.omitidos} omitidos, ${stats.errores} errores ---`);
  generarReporteEnvio(stats.enviados, stats.omitidos, stats.errores, nitAgrupado);
}


// ============================================================
//  HELPERS DE LA FUNCIÓN PRINCIPAL

// Recibe la fecha actual y la devuelve formateada como string.
// Se usa en varios lugares para no repetir el mismo Utilities.formatDate.
function fechaHoy() {
  return Utilities.formatDate(new Date(), ZONA_HORARIA, "dd/MM/yyyy");
}

function horaAhora() {
  return Utilities.formatDate(new Date(), ZONA_HORARIA, "HH:mm:ss");
}

// Escribe estado, fecha y hora en las filas correspondientes a un NIT.
function registrarEstado(hoja, filas, colEstado, colFecha, colHora, estado) {
  const fecha = fechaHoy();
  const hora  = horaAhora();
  filas.forEach(f => {
    hoja.getRange(f.filaExcel, colEstado).setValue(estado);
    hoja.getRange(f.filaExcel, colFecha).setValue(fecha);
    hoja.getRange(f.filaExcel, colHora).setValue(hora);
  });
}

// Limpia el nombre de la administración eliminando sufijos de unidad
// que vienen pegados en la base de datos (ej: "ALIADAS CSA 164" → "ALIADAS").
// Si el regex falla con algún nuevo formato, revisar patronesSufijo abajo.
function limpiarNombreAdmin(nombreCompleto) {
  if (!nombreCompleto) return "";

  let nombre = nombreCompleto.trim();

  const patronesSufijo = [
    /\s+APTO\s+\S+$/i,
    /\s+APT\s+\S+$/i,
    /\s+CSA\s+\S+$/i,
    /\s+P\.H\.\s*\S*$/i,
    /\s+PH\s+\S+$/i,
    /\s+CASA\s+\S+$/i,
    /\s+TORRE\s+\S+$/i,
    /\s+\d+(\s*\-\s*\d+)?$/,
    /\s+N[°o]?\s*\d+$/i,
  ];

  // Aplica los patrones en loop hasta que no haya nada más que eliminar
  let anterior;
  do {
    anterior = nombre;
    for (const patron of patronesSufijo) {
      nombre = nombre.replace(patron, "").trim();
    }
  } while (nombre !== anterior);

  nombre = nombre.replace(/[\s,\-]+$/, "").trim();
  return nombre || nombreCompleto.trim();
}

// Devuelve o crea la columna de control buscada por nombre.
// Así no dependemos de posiciones fijas y el script aguanta reordenamientos.
function obtenerOCrearColumna(hoja, encabezados, nombreColumna) {
  const idx = encabezados.indexOf(nombreColumna);
  if (idx !== -1) return idx + 1; // ya existe, retorna posición 1-based

  const nuevaCol = hoja.getLastColumn() + 1;
  hoja.getRange(1, nuevaCol).setValue(nombreColumna);
  return nuevaCol;
}



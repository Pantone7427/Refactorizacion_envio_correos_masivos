//  REPORTE AUTOMÁTICO EN HOJA NUEVA
// ============================================================

function generarReporteEnvio(enviados, omitidos, errores, nitAgrupado) {
  const ss   = SpreadsheetApp.getActiveSpreadsheet();
  const hoja = ss.getSheetByName(NOMBRE_HOJA);
  const datos = hoja.getDataRange().getDisplayValues();
  const encabezados = datos[0];

  const colEstadoIdx = encabezados.indexOf("Estado");
  const colHoraIdx   = encabezados.indexOf("Hora Envío");
  const ahora        = new Date();

  const nombreHoja = "Reporte_" + Utilities.formatDate(ahora, ZONA_HORARIA, "dd-MM-yyyy_HH-mm");
  const hojaR      = ss.insertSheet(nombreHoja);

  // Encabezado principal
  hojaR.getRange("A1:F1").merge()
    .setValue("REPORTE DE ENVÍO MASIVO — ARRENDAMIENTOS EL CASTILLO")
    .setFontSize(14).setFontWeight("bold").setHorizontalAlignment("center")
    .setBackground("#1b4332").setFontColor("#ffffff");

  // Fecha y hore de generación
  hojaR.getRange("A3").setValue("Fecha:").setFontWeight("bold");
  hojaR.getRange("B3").setValue(fechaHoy());
  hojaR.getRange("A4").setValue("Hora:").setFontWeight("bold");
  hojaR.getRange("B4").setValue(horaAhora());

  // Cuadro de resumen
  const total = enviados + omitidos + errores;
  hojaR.getRange("D3:F3").merge().setValue("RESUMEN")
    .setFontWeight("bold").setHorizontalAlignment("center").setBackground("#d8f3dc");

  [
    ["D4", "Total administraciones:", total,    "#ffffff"],
    ["D5", "Enviados:",               enviados,  "#d4edda"],
    ["D6", "Omitidos:",               omitidos,  "#fff3cd"],
    ["D7", "Errores:",                errores,   "#f8d7da"]
  ].forEach(([col, label, val, bg]) => {
    hojaR.getRange(col).setValue(label).setFontWeight("bold");
    hojaR.getRange(col.replace("D", "E")).setValue(val).setBackground(bg).setFontWeight("bold");
  });

  // Tabla de envío exitosos
  let fila = 9;
  fila = escribirSeccionReporte(hojaR, fila, "ENVÍOS EXITOSOS", ["NIT", "Nombre", "Email", "Contratos", "Direcciones", "Hora envío"]);

  const filaInicioExitosos = fila;
  for (const nit in nitAgrupado) {
    const admin = nitAgrupado[nit];
    const estadoFila = hoja.getRange(admin.filas[0].filaExcel, colEstadoIdx + 1).getDisplayValue();

    if (estadoFila === "ENVIADO") {
      const contratos   = admin.filas.map(f => f.contrato).join(", ");
      const direcciones = admin.filas.map(f => f.direccionInmueble).join(" | ");
      const horaEnvio   = colHoraIdx !== -1 ? datos[admin.filas[0].filaExcel - 1][colHoraIdx] : "";
      hojaR.getRange(fila, 1, 1, 6).setValues([[nit, admin.nombreAdmin, admin.email, contratos, direcciones, horaEnvio]]);
      fila++;
    }
  }
  if (fila > filaInicioExitosos) {
    hojaR.getRange(filaInicioExitosos - 1, 1, fila - filaInicioExitosos + 1, 6)
      .setBorder(true, true, true, true, true, true);
  }

  // Tabla de problemas (cuando se generen errores)
  if (errores > 0) {
    fila += 2;
    fila = escribirSeccionReporte(hojaR, fila, "PROBLEMAS", ["NIT", "Nombre", "Email", "Estado", "Observación"]);

    const filaInicioProblemas = fila;
    for (const nit in nitAgrupado) {
      const admin = nitAgrupado[nit];
      const estadoFila = hoja.getRange(admin.filas[0].filaExcel, colEstadoIdx + 1).getDisplayValue();

      if (estadoFila !== "ENVIADO" && estadoFila !== "") {
        const observacion =
          estadoFila === "SIN EMAIL"       ? "No tiene correo registrado en la base" :
          estadoFila === "SIN ARCHIVO"     ? "Archivo de soporte no encontrado en Drive" :
          estadoFila.startsWith("ERROR")   ? estadoFila : "";

        hojaR.getRange(fila, 1, 1, 5).setValues([[nit, admin.nombreAdmin, admin.email || "N/A", estadoFila, observacion]]);
        fila++;
      }
    }

    if (fila > filaInicioProblemas) {
      hojaR.getRange(filaInicioProblemas - 1, 1, fila - filaInicioProblemas + 1, 5)
        .setBorder(true, true, true, true, true, true);
    }
  }

  // Pie de página
  fila += 2;
  hojaR.getRange(fila, 1, 1, 6).merge()
    .setValue("Reporte generado automáticamente — Sistema de Envío Masivo · Arrendamientos El Castillo")
    .setFontStyle("italic").setFontColor("#2d6a4f");

  // Ancho de columnas y fila fija
  [100, 220, 200, 150, 200, 100].forEach((w, i) => hojaR.setColumnWidth(i + 1, w));
  hojaR.setFrozenRows(1);

  Logger.log(`Reporte generado: ${nombreHoja}`);
}

// Escribe el encabezado de sección en el reporte y devuelve la siguiente fila disponible.
function escribirSeccionReporte(hoja, fila, titulo, columnas) {
  hoja.getRange(fila, 1, 1, columnas.length).merge()
    .setValue(titulo).setFontSize(12).setFontWeight("bold")
    .setBackground("#1b4332").setFontColor("#ffffff");
  fila++;

  hoja.getRange(fila, 1, 1, columnas.length)
    .setValues([columnas]).setFontWeight("bold").setBackground("#d8f3dc");
  fila++;

  return fila;
}

// --- Constantes ---

const NOMBRE_HOJA    = "Base_Pagos";
const ID_CARPETA     = "14TBWRq5qgBi6BJZ2PKtOK_lfDyx2qB3T";
const ZONA_HORARIA   = Session.getScriptTimeZone();

// Índices de columnas de datos (0-based)
const COL_CONTRATO   = 0;
const COL_NIT        = 1;
const COL_NOMBRE     = 2;
const COL_VALOR      = 3;
const COL_EGRESO     = 4;
const COL_EMAIL      = 5;


// ============================================================
//  UTILIDADES GENERALES

// Lee todos los archivos de la carpeta de Drive y los indexa por el número
// que aparece antes del primer guion en el nombre del archivo (ej: "20062_...").
function cargarArchivosDesideDrive() {
  const carpeta    = DriveApp.getFolderById(ID_CARPETA);
  const iterador   = carpeta.getFiles();
  const mapa       = {};

  while (iterador.hasNext()) {
    const archivo = iterador.next();
    const match   = archivo.getName().match(/^(\d+)_/);
    if (match) mapa[match[1]] = archivo;
  }

  Logger.log(`Archivos cargados desde Drive: ${Object.keys(mapa).length}`);
  return mapa;
}

// Convierte las filas de la hoja en un objeto agrupado por NIT.
// Cada entrada tiene los datos de la administración y un array de filas.
function agruparFilasPorNit(datos) {
  const agrupado = {};

  for (let i = 1; i < datos.length; i++) {
    const fila           = datos[i];
    const nit            = fila[COL_NIT].trim();
    const nombreCompleto = fila[COL_NOMBRE].trim();
    const egresoCompleto = fila[COL_EGRESO].trim();
    const partes         = egresoCompleto.split("-");
    const numRef         = partes[partes.length - 1].trim();

    if (!agrupado[nit]) {
      agrupado[nit] = {
        nombreAdmin: limpiarNombreAdmin(nombreCompleto),
        email:       fila[COL_EMAIL].trim(),
        filas:       []
      };
    }

    agrupado[nit].filas.push({
      filaExcel:         i + 1,
      contrato:          fila[COL_CONTRATO].trim(),
      valor:             fila[COL_VALOR].trim(),
      egresoCompleto,
      numRef,
      direccionInmueble: nombreCompleto
    });
  }

  return agrupado;
}

// Busca los archivos en el mapa de Drive para cada fila del grupo.
// Devuelve dos listas: los que sí encontró y los que no.
function resolverAdjuntos(filas, mapaArchivos) {
  const adjuntos  = [];
  const faltantes = [];

  filas.forEach(f => {
    if (mapaArchivos[f.numRef]) {
      adjuntos.push({
        blob:              mapaArchivos[f.numRef].getBlob(),
        contrato:          f.contrato,
        valor:             f.valor,
        egresoCompleto:    f.egresoCompleto,
        numRef:            f.numRef,
        filaExcel:         f.filaExcel,
        direccionInmueble: f.direccionInmueble
      });
    } else {
      faltantes.push(f);
      Logger.log(`Archivo no encontrado: ref ${f.numRef}`);
    }
  });

  return { adjuntos, faltantes };
}


// ============================================================
//  ENVÍO DE CORREO
// ============================================================

function enviarCorreo(admin, adjuntos) {
  MailApp.sendEmail({
    to:       admin.email,
    subject:  `Soporte de pago — ${admin.nombreAdmin}`,
    htmlBody: construirHtmlCorreo(admin, adjuntos),
    attachments: adjuntos.map(a => a.blob)
  });
}

